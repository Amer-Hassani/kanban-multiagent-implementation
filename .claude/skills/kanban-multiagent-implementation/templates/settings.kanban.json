      "Bash(npm run test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run dev)",
      "Bash(npm run dev:*)",
      "Bash(npm start)",
      "Bash(npm start:*)",
      "Bash(npx vitest:*)",
