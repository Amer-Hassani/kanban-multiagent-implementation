{
  "_comment": "kanban-multiagent-implementation — SESSION-WIDE permissions, merged (array-union, not overwrite) into the project's .claude/settings.json at setup. These apply to ALL agents equally — correct for secrets, config, and irreversible ops. PER-AGENT scoping lives in templates/hooks/. File rules use Edit(...) not Write(...) (a Write(path) rule is accepted but never matched as of Claude Code v2.1.210; a Read deny also blocks Edit on the same path). Bash rules need BOTH the bare form and the :* prefix form to match exact and argument'd invocations. EDIT the test/build/lint/serve commands to match this project.",

  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.dev.vars)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p8)",
      "Read(**/*.p12)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.git-credentials)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/*.tfvars)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Read(**/wrangler.toml)",
      "Read(**/wrangler.jsonc)",
      "Edit(.claude/**)",
      "Edit(**/CLAUDE.md)",
      "Edit(**/AGENTS.md)",
      "Edit(.mcp.json)",
      "Bash(npm install:*)",
      "Bash(npm install)",
      "Bash(npm i:*)",
      "Bash(npm i)",
      "Bash(yarn add:*)",
      "Bash(pnpm add:*)",
      "Bash(pip install:*)",
      "Bash(npm publish:*)",
      "Bash(git push:*)",
